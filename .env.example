# ORSA environment configuration.
# Copy to .env (gitignored) and fill in. Both services walk up to the repo root
# to find this file; OS/process env always overrides file values.

# ── Shared session auth ──────────────────────────────────────────────────────
# HS256 secret shared by the Go gateway (verifies) and the C# auth service
# (mints). REQUIRED in production. If unset, both services fall back to an
# insecure dev secret and log a warning.
ORSA_SESSION_SECRET=

# ── Go AI gateway (services/go-ai-mongo) ─────────────────────────────────────
HTTP_PORT=3000
# Comma-separated browser origins allowed to call the REST API (CORS).
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Chat persistence (falls back to in-memory when unset).
MONGODB_ATLAS_URI=
MONGODB_DATABASE=orsa

# Clinical knowledge + specialist ESI model.
UMLS_API_KEY=
BERT_BASE_MODEL_ID=emilyalsentzer/Bio_ClinicalBERT
BERT_ESI_MODEL_DIR=./models/bert_esi
BERT_ESI_ONNX_DIR=./models/bert_esi_onnx
# Absolute path to onnxruntime.dll (Windows) or libonnxruntime.so.* (Linux).
# ONNX_RUNTIME_LIB is the app-specific alias; ONNXRUNTIME_SHARED_LIBRARY_PATH
# matches github.com/yalue/onnxruntime_go docs and is also accepted.
ONNXRUNTIME_SHARED_LIBRARY_PATH=
ONNX_RUNTIME_LIB=

# Vision attachment ingestion (GitHub Models / Azure inference).
GITHUB_MODELS_BASE=https://models.inference.ai.azure.com
VISION_MODEL_ID=meta/Llama-3.2-90B-Vision-Instruct
GITHUB_TOKEN=

# Extra GitHub Models that join the round-robin pool (text + vision). They reuse
# GITHUB_TOKEN. Verify the exact model-id strings against the GitHub Models catalog.
GITHUB_GPT_MODEL_ID=openai/gpt-4.1
GITHUB_LLAMA_MODEL_ID=meta/Llama-4-Maverick-17B-128E-Instruct-FP8

# Google Gemini (OpenAI-compatible surface) — joins both pools when the key is set.
GEMINI_BASE=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL_ID=gemini-2.5-flash
GEMINI_API_KEY=

# GPT-OSS conversational triage (Hugging Face Router, OpenAI-compatible).
GPT_OSS_ENDPOINT=https://router.huggingface.co/v1
GPT_OSS_MODEL_ID=openai/gpt-oss-120b
GPT_OSS_AUTH_TOKEN=

# C# engine endpoint consumed by the Go gateway over gRPC.
CSHARP_SUPABASE_GRPC_URL=localhost:50053

# ── C# Supabase engine (services/csharp-supabase) ────────────────────────────
GRPC_PORT=50053
HEALTH_PORT=8085
SUPABASE_DB_CONNECTION_STRING=

# Google OAuth (optional; sign-in is disabled until these are set).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Email verification (Mailtrap). When MAILTRAP_API_TOKEN is unset, verification
# emails are skipped (a warning is logged) and email/password users land unverified.
# Get a sending token from mailtrap.io → Sending → API Tokens.
MAILTRAP_API_TOKEN=
# Must be an address on a Mailtrap-verified sending domain.
MAILTRAP_FROM_ADDRESS=noreply@yourdomain.com
MAILTRAP_FROM_NAME=ORSA
# Base URL of the frontend, used to build the verification link
# ({APP_BASE_URL}/verify-email?token=...).
APP_BASE_URL=http://localhost:4200
